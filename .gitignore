# --- Virtual Environments ---
# Prevents thousands of library files from bloating your repo
.venv/
venv/
env/

# --- Secrets & API Keys ---
# Protects your Gemini API key from being exposed publicly
.env

# --- Data Layer ---
# Ignores local CSV files and generated reports to keep the repo focused on logic
data/

# --- Code Layer ---
src/ingestor.py
src/backfill_reports.py
src/publish.sh
src/scout.py

# --- Python & System Caches ---
# Ignores temporary files that Python generates to run
__pycache__/
*.py[cod]
.DS_Store